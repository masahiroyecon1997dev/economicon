# 動的バリデーションメッセージテンプレート
msgid "{field} is required"
msgstr "{field}は必須です。"

msgid "{field} must be a string"
msgstr "{field}は文字列で入力してください。"

msgid "{field} must be an integer"
msgstr "{field}は整数で入力してください。"

msgid "{field} must be a number"
msgstr "{field}は数値で入力してください。"

msgid "{field} must be a boolean"
msgstr "{field}は真偽値で入力してください。"

msgid "{field} must be a list"
msgstr "{field}はリストで入力してください。"

msgid "{field} must be a dictionary"
msgstr "{field}は辞書で入力してください。"

msgid "{field} must be at least {min_length} characters"
msgstr "{field}は{min_length}文字以上で入力してください。"

msgid "{field} must be at most {max_length} characters"
msgstr "{field}は{max_length}文字以内で入力してください。"

msgid "{field} must be one of: {expected}"
msgstr "{field}は次のいずれかである必要があります: {expected}"

msgid "{field} has an invalid value"
msgstr "{field}の値が無効です。"

msgid "{field} must have at least {min_length} items"
msgstr "{field}は{min_length}件以上ある必要があります。"

msgid "{field} must be less than {lt}"
msgstr "{field}は{lt}未満で入力してください。"

msgid "{field} must be less than or equal to {le}"
msgstr "{field}は{le}以下で入力してください。"

msgid "{field} must be greater than {gt}"
msgstr "{field}は{gt}より大きい値で入力してください。"

msgid "{field} must be greater than or equal to {ge}"
msgstr "{field}は{ge}以上で入力してください。"

msgid "{field} has an invalid type"
msgstr "{field}のタイプが正しくありません。"

msgid "{field} contains invalid characters"
msgstr "{field}に使用できない文字が含まれています。"

