msgstr "二項分布では、'p'は0から1の間である必要があります"

#: analysisapp/utils/validator/statistics_validators.py:113
msgid "Bernoulli distribution requires 'p' parameter"
msgstr "ベルヌーイ分布には'p'パラメータが必要です"

#: analysisapp/utils/validator/statistics_validators.py:117
msgid "For bernoulli distribution, 'p' must be between 0 and 1"
msgstr "ベルヌーイ分布では、'p'は0から1の間である必要があります"

#: analysisapp/utils/validator/statistics_validators.py:121
msgid "Poisson distribution requires 'lam' parameter"
msgstr "ポアソン分布には'lam'パラメータが必要です"

#: analysisapp/utils/validator/statistics_validators.py:125
msgid "For poisson distribution, 'lam' must be positive"
msgstr "ポアソン分布では、'lam'は正の値である必要があります"

#: analysisapp/utils/validator/statistics_validators.py:129
msgid "Geometric distribution requires 'p' parameter"
msgstr "幾何分布には'p'パラメータが必要です"

#: analysisapp/utils/validator/statistics_validators.py:133
msgid "For geometric distribution, 'p' must be between 0 and 1 (exclusive of 0)"
msgstr "幾何分布では、'p'は0と1の間である必要があります(0を除く)"

#: analysisapp/utils/validator/statistics_validators.py:138
msgid "Hypergeometric distribution requires 'N', 'K', and 'n' parameters"
msgstr "超幾何分布には'N','K','n'パラメータが必要です"

#: analysisapp/utils/validator/statistics_validators.py:144
msgid "For hypergeometric distribution, 'N', 'K', and 'n' must be positive"
msgstr "超幾何分布では、'N','K','n'は正の値である必要があります"

#: analysisapp/utils/validator/statistics_validators.py:148
msgid "For hypergeometric distribution, 'K' must not exceed 'N'"
msgstr "超幾何分布では、'K'は'N'を超えてはいけません"

#: analysisapp/utils/validator/statistics_validators.py:152
msgid "For hypergeometric distribution, 'n' must not exceed 'N'"
msgstr "超幾何分布では、'n'は'N'を超えてはいけません"

#: analysisapp/utils/validator/statistics_validators.py:198
msgid "Dependent variable cannot be included in explanatory variables"
msgstr "被説明変数を説明変数に含めることはできません。"

