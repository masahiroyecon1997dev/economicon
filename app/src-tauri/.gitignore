# Generated by Cargo
# will have compiled files and executables
/target/
/gen/schemas


# Tauriの依存バイナリ（サイドカーや配布用バイナリなど）
src-tauri/bin/*
!src-tauri/bin/.gitkeep

# OS固有のゴミファイル
.DS_Store
Thumbs.db

# ログファイル
*.log

# (オプション) ローカルのEmbedded Python環境
# 環境構築用のスクリプトだけGitに入れ、中身は除外するのが一般的です
src-tauri/python-env/
