{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "api-server",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/ApiServer/analysisapp/manage.py",
            "args": [
                "runserver",
                "8000"
            ],
            "django": true,
            "console": "integratedTerminal"
        },
        {
            "name": "Launch Chrome",
            "type": "chrome",
            "request": "launch",
            "preLaunchTask": "yarn: start",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}/front-analysis-app",
            "sourceMaps": true,
            "sourceMapPathOverrides": {
                "webpack:///./~/*": "${webRoot}/node_modules/*",
                "webpack://?:*/*": "${webRoot}/src/*"
            }
        }
    ]
}
