{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "api-server",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"],
      "cwd": "${workspaceFolder}/api",
      "console": "integratedTerminal",
      "env": {
        "economicon_DEV_RUN": "true"
      }
    },
    {
      "name": "Tauri Development (Windows)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/app/src-tauri/target/debug/economicon.exe",
      "args": [],
      "cwd": "${workspaceFolder}/app",
      "stopAtEntry": false,
      "preLaunchTask": "pnpm: start"
    },
    {
      "name": "pytest",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests", "-v"],
      "justMyCode": false,
      "cwd": "${workspaceFolder}/api"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack Debug (API + Tauri)",
      "configurations": ["api-server", "Tauri Development (Windows)"],
      "stopAll": true,
      "presentation": {
        "hidden": false,
        "group": "Full Stack",
        "order": 1
      }
    }
  ]
}
